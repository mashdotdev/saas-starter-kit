  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^7.6.0",
    "@types/node": "^25.5.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prisma": "^7.6.0",
    "typescript": "^5"
  }
}
